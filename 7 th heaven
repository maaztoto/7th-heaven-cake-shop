<!DOCTYPE html>
<html>
<head>
<title>7th Heaven Cake Shop Magarpatta</title>

<style>
body{
font-family: Arial;
background:#111;
color:white;
text-align:center;
}

header{
background:#ff4d6d;
padding:20px;
font-size:28px;
}

.menu{
display:flex;
justify-content:center;
gap:30px;
margin-top:40px;
flex-wrap:wrap;
}

.card{
background:#222;
padding:20px;
border-radius:10px;
width:200px;
}

button{
background:#25D366;
border:none;
padding:10px 20px;
color:white;
font-size:16px;
border-radius:5px;
cursor:pointer;
}
</style>
</head>

<body>

<header>
7th Heaven Cake Shop 🍰
<br>
Magarpatta Pune
</header>

<h2>Our Cakes</h2>

<div class="menu">

<div class="card">
<h3>Chocolate Truffle</h3>
<p>₹500</p>
<button onclick="order('Chocolate Truffle')">Order</button>
</div>

<div class="card">
<h3>Red Velvet</h3>
<p>₹600</p>
<button onclick="order('Red Velvet')">Order</button>
</div>

<div class="card">
<h3>Black Forest</h3>
<p>₹450</p>
<button onclick="order('Black Forest')">Order</button>
</div>

<div class="card">
<h3>Butterscotch</h3>
<p>₹450</p>
<button onclick="order('Butterscotch')">Order</button>
</div>

</div>

<br><br>

<h2>Custom Cake Order</h2>

<input id="name" placeholder="Your Name"><br><br>
<input id="phone" placeholder="Phone Number"><br><br>
<input id="cake" placeholder="Cake Flavor"><br><br>
<input id="weight" placeholder="Weight (1kg etc)"><br><br>

<button onclick="sendOrder()">Place Order</button>

<script>

function order(cake){
window.open("https://wa.me/918411942100?text=I want to order "+cake);
}

function sendOrder(){

let name=document.getElementById("name").value;
let phone=document.getElementById("phone").value;
let cake=document.getElementById("cake").value;
let weight=document.getElementById("weight").value;

let message=`New Cake Order
Name: ${name}
Phone: ${phone}
Cake: ${cake}
Weight: ${weight}`;

let url="https://wa.me/918411942100?text="+encodeURIComponent(message);

window.open(url);
}

</script>

</body>
</html>
